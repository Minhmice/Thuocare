{
  "name": "@thuocare/mobile",
  "main": "index.js",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start --go",
    "start:clear": "expo start --go --clear",
    "start:dev-client": "EXPO_USE_DEV_CLIENT=1 expo start --dev-client",
    "android": "expo start --android --go",
    "android:run": "EXPO_USE_DEV_CLIENT=1 expo run:android",
    "ios": "expo start --ios --go",
    "ios:run": "EXPO_USE_DEV_CLIENT=1 expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"add eslint when needed\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-navigation/native": "^7.1.33",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.95.2",
    "@thuocare/auth": "workspace:*",
    "@thuocare/supabase": "workspace:*",
    "@thuocare/utils": "workspace:*",
    "@thuocare/validation": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.18",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.10",
    "nativewind": "5.0.0-preview.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-native": "0.83.2",
    "react-native-css": "^3.0.6",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  }
}
