{
  "expo": {
    "name": "Thuocare",
    "slug": "thuocare-mobile",
    "scheme": "thuocare",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-navigation-bar",
        {
          "enforceContrast": false,
          "barStyle": "dark",
          "visibility": "visible"
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Thuocare needs photo access to attach a screenshot to your feedback.",
          "cameraPermission": "Thuocare needs camera access if you take a photo for feedback."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.thuocare-mobile",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.anonymous.thuocare.mobile",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "expo-navigation-bar": {
        "enforceContrast": false,
        "barStyle": "dark",
        "visibility": "visible"
      },
      "eas": {
        "projectId": "0b20d3ee-dbc1-4e8d-87e3-3b6c2443a372"
      }
    }
  }
}
